{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "email": {
      "type": ["string",
      "null"]
    },
    "phone": {
      "type": ["string",
        "null"]
    },
    "serviceType": {
      "type": "string"
    },
    "createdAt": {
      "type": "string"
    }
  },
  "required": ["id", "name", "serviceType"]
}