{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id":        { "type": "integer" },
    "name":      { "type": "string" },
    "email":     { "type": ["string", "null"] },
    "phone":     { "type": ["string", "null"] },
    "company":   { "type": ["string", "null"] },
    "createdAt": { "type": ["string", "null"] }
  }
}